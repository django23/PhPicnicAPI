{
    "name": "django23/php-picnic-api",
    "description": "Unofficial, framework-agnostic PHP client for the Picnic supermarket API (PSR-18).",
    "type": "library",
    "license": "MIT",
    "keywords": ["picnic", "api", "client", "supermarket", "groceries", "psr-18"],
    "homepage": "https://github.com/django23/PhPicnicAPI",
    "authors": [
        {
            "name": "Django Eijgensteijn",
            "homepage": "https://github.com/django23"
        }
    ],
    "require": {
        "php": ">=8.4",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "php-http/mock-client": "^1.6",
        "guzzlehttp/guzzle": "^7.8",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "PhPicnic\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhPicnic\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
